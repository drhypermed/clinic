# SMTP settings for OTP emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com

# OTP pepper - REQUIRED in production (use a strong random string)
OTP_PEPPER=replace-with-strong-random-secret

# Root admin credentials - REQUIRED
ROOT_ADMIN_UID=your-firebase-admin-uid-here
ROOT_ADMIN_EMAIL=your-admin-email@example.com

# App Check enforcement (default: true on all)
# Set to 'false' only if you need to debug or if App Check breaks a specific flow.
# ENFORCE_APP_CHECK=true                   # All admin/base functions
# GEMINI_ENFORCE_APP_CHECK=true            # Gemini AI calls
# ACCOUNT_CONTROLS_ENFORCE_APP_CHECK=true  # Quota consumers (consume*Quota, getAccountTypeControls)

# Optional: Custom bucket for daily Firestore backups. If not set, uses the project's
# default storage bucket. The scheduled function `scheduledFirestoreExport` runs daily
# at 02:30 Cairo time, exports Firestore to gs://<bucket>/firestore-backups/YYYY-MM-DD/
# and deletes backups older than 30 days.
# FIRESTORE_BACKUP_BUCKET=your-custom-bucket-name
